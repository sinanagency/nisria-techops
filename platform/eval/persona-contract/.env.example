# nisria-sasa eval — env vars
#
# Copy to .env (or export in your shell) before running `npm run eval:contract`.
# The runtime audit is read-only; the service key is required only because the
# Sasa `messages` table is service-role gated.

# Supabase REST endpoint for the Sasa project (ref ptvhqudonvvszupzhcfl).
SUPABASE_URL=

# Service-role key. Treat as a secret. Read-only use here.
SUPABASE_SERVICE_KEY=

# --- optional overrides ---

# Bot name surfaced in report JSON. Defaults to nisria-sasa.
# BOT_NAME=nisria-sasa

# Days of outbound history to scan. Defaults to 30 per SPEC §7.7.
# NEG_EVAL_WINDOW_DAYS=30

# Outbound table + filters (Sasa default: messages where direction='out' and handled_by='sasa').
# NEG_EVAL_TABLE=messages
# NEG_EVAL_DIRECTION=out
# NEG_EVAL_HANDLED_BY=sasa

# Platform repo root (static tool-schema audit reads from here).
# NISRIA_PLATFORM_ROOT=/Users/milaaj/Code/nisria-techops/platform

# Set to 1 to make MEDIUM-severity violations block CI. Default 0 (warn-only).
# NEG_EVAL_BLOCK_MEDIUM=0
