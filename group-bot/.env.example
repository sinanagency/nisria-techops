# Copy to Railway service variables (do NOT commit a real .env)
PLATFORM_URL=https://command.nisria.co
GROUP_BOT_SECRET=set-the-same-value-as-the-platform-env
AUTH_DIR=/data/auth
# optional: only act in groups whose name contains one of these (comma separated). empty = all groups
GROUP_ALLOWLIST=Nisria,Maisha
LOG_LEVEL=info
# optional: route the WhatsApp session through a sticky residential/mobile proxy
# (Kenya geo ideal) so the login does not come from a datacenter IP. Empty = direct.
# socks5://user:pass@host:port  or  http://user:pass@host:port
PROXY_URL=
# optional: minimum gap between outbound sends in ms (anti-ban pacing). default 2500
MIN_SEND_GAP_MS=2500
