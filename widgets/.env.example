# Copy to .env.local (Vercel: set as project env vars). Never commit real values.
# Use the Supabase ANON key — these widgets read only public data
# (campaigns meta + public_beneficiary_profiles view). RLS must restrict the rest.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
