    {
      "type": "text", "id": "tools_title", "x": 1310, "y": 316, "width": 560, "height": 24,
      "text": "5 · TOOLS & GUARDS", "originalText": "5 · TOOLS & GUARDS",
      "fontSize": 18, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#334155", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
